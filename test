-- ============= MINIMIZE & DRAG =============
local minimized = false
local fullSize = UDim2.fromOffset(300,460)
local minSize = UDim2.fromOffset(300,32)
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function toggleMinimize()
    minimized = not minimized
    TweenService:Create(mainFrame, tweenInfo, {Size = minimized and minSize or fullSize}):Play()
end
minimizeLine.MouseButton1Click:Connect(toggleMinimize)

local dragging = false
local lastPos = Vector2.new()

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        lastPos = input.Position
    end
end)

topBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - lastPos
        mainFrame.Position += UDim2.fromOffset(delta.X, delta.Y)
        lastPos = input.Position
    end
end)

-- ============= TAB SWITCHING =============
local function switchToSpeed()
    speedTab.BackgroundColor3 = COLOR_RED_ENABLED
    turnTab.BackgroundColor3 = COLOR_BG_PANEL
    flyTab.BackgroundColor3 = COLOR_BG_PANEL
    speedContent.Visible = true
    turnContent.Visible = false
    flyContent.Visible = false
end

local function switchToTurn()
    speedTab.BackgroundColor3 = COLOR_BG_PANEL
    turnTab.BackgroundColor3 = COLOR_RED_ENABLED
    flyTab.BackgroundColor3 = COLOR_BG_PANEL
    speedContent.Visible = false
    turnContent.Visible = true
    flyContent.Visible = false
end

local function switchToFly()
    speedTab.BackgroundColor3 = COLOR_BG_PANEL
    turnTab.BackgroundColor3 = COLOR_BG_PANEL
    flyTab.BackgroundColor3 = COLOR_RED_ENABLED
    speedContent.Visible = false
    turnContent.Visible = false
    flyContent.Visible = true
end

speedTab.MouseButton1Click:Connect(switchToSpeed)
turnTab.MouseButton1Click:Connect(switchToTurn)
flyTab.MouseButton1Click:Connect(switchToFly)

